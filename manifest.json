{
  "name": "Quantum",
  "short_name": "Quantum",
  "description": "The Goorac Quantum official web app.",
  "start_url": "/home.html",
  "scope": "/",
  "display": "standalone",
  "orientation": "any",
  "background_color": "#121212",
  "theme_color": "#121212",
  "dir": "ltr",
  "lang": "en",
  "categories": ["utilities", "productivity"],
  "icons": [
    {
      "src": "images/icon-quantum.png",
      "type": "image/png",
      "sizes": "1024x1024",
      "purpose": "any"
    },
    {
      "src": "images/icon-quantum.png",
      "type": "image/png",
      "sizes": "1024x1024",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Open Home",
      "short_name": "Home",
      "description": "Go directly to the home screen",
      "url": "/home.html",
      "icons": [
        {
          "src": "images/icon-quantum.png",
          "sizes": "1024x1024"
        }
      ]
    },
    {
      "name": "Messages",
      "short_name": "Messages",
      "description": "Go directly to your messages",
      "url": "/messages.html",
      "icons": [
        {
          "src": "images/icon-quantum.png",
          "sizes": "1024x1024"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/api/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "shared_files",
          "accept": ["image/*", "video/*", "application/*", "text/*", "audio/*"]
        }
      ]
    }
  }
